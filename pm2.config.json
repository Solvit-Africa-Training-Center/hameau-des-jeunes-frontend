{
  "apps": [{
    "name": "hameau-front",
    "script": "npm run preview -- --port 3050",
    "cwd": "/var/www/hameau-frontend",
    "instances": 1,
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "development",
      "PORT": 3050
    },
    "env_production": {
      "NODE_ENV": "production",
      "PORT": 3050,
      "API_URL": "https://hameaudesjeunes.org/"
    },
    "log_date_format": "YYYY-MM-DD HH:mm Z",
    "error_file": "./logs/err.log",
    "out_file": "./logs/out.log",
    "log_file": "./logs/combined.log",
    "time": true,
    "max_memory_restart": "1G",
    "node_args": "--max_old_space_size=1024",
    "watch": false,
    "ignore_watch": ["node_modules", "logs", "dist"],
    "kill_timeout": 5000,
    "restart_delay": 1000,
    "autorestart": true,
    "max_restarts": 10,
    "min_uptime": "10s",
    "exp_backoff_restart_delay": 100
  }]
}
